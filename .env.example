# ====== DATABASE ======
# SQL Server connection credentials for Sage 300 database
DB_USER=your_db_user  # (renamed from USER to avoid collision with OS USER env var)
DB_PASSWORD=your_db_password
SERVER=your_sql_server_host
DATABASE=YOUR_DATABASE_NAME

# ====== PORTAL (Focaltec) ======
# Portal de Proveedores API connection
# For multiple tenants, separate each value with commas (same index = same tenant)
# Example: TENANT_ID=tenant1,tenant2  API_KEY=key1,key2  etc.
URL=https://api-sandbox.portaldeproveedores.mx
TENANT_ID=your_tenant_id
API_KEY=your_api_key
API_SECRET=your_api_secret_token
DATABASES=YOUR_DATABASE_NAME
EXTERNAL_IDS=YOUR_RFC_ID
# Timeout HTTP de axios al portal (ROOT-01, v2.3)
# Default 30s. Min: 1000 (1 sec). Afecta los 18 axios call sites en 9 controllers/utils.
# PORTAL_HTTP_TIMEOUT_MS=30000

# ====== MAILING ======
# Transport type: "smtp" for corporate SMTP server, "gmail" for Gmail OAuth
MAIL_TRANSPORT=smtp
# SMTP settings (used when MAIL_TRANSPORT=smtp)
eFrom=notificaciones@tuempresa.com
ePass=tu_password_email
eServer=mail.tuempresa.com
ePuerto=587
eSSL=TRUE
# Notification recipients (comma-separated for multiple)
MAILING_NOTICES=admin@tuempresa.com
MAILING_CC=backup@tuempresa.com,supervisor@tuempresa.com
# Gmail OAuth settings (used when MAIL_TRANSPORT=gmail)
CLIENT_ID=your-client-id.apps.googleusercontent.com
SECRET_CLIENT=GOCSPX-your_client_secret
REFRESH_TOKEN=1//your_refresh_token
REDIRECT_URI=https://developers.google.com/oauthplayground

# ====== PATHS ======
# Local filesystem paths for downloads and logs
DOWNLOADS_PATH=./downloads  # (renamed from PATH to avoid collision with OS PATH env var)
PROVIDERS_PATH=./downloads/providers
LOG_PATH=./logs

# ====== APP ======
# Path to the CFDI import executable (ImportaFacturasFocaltec.exe)
IMPORT_CFDIS_ROUTE=C:\Program Files (x86)\Importa CFDIs AP - Focaltec\ImportaFacturasFocaltec.exe
# Sage 300 database argument passed to the import executable
ARG=YOUR_DATABASE_NAME
# Company information for invoice processing
NOMBRE=Tu Empresa SA de CV
RFC=ABC123456DEF
# SAT tax regime code (e.g., 601=General de Ley, 603=Personas Morales sin fines de lucro)
REGIMEN=601
# IANA timezone for date/time operations
TIMEZONE=America/Mexico_City
# Default address for purchase orders when no data exists in Sage ICLOC table
DEFAULT_ADDRESS_CITY=TU_CIUDAD
DEFAULT_ADDRESS_COUNTRY=MEXICO
DEFAULT_ADDRESS_IDENTIFIER=ID_EXAMPLE
DEFAULT_ADDRESS_MUNICIPALITY=TU_MUNICIPIO
DEFAULT_ADDRESS_STATE=TU_ESTADO
DEFAULT_ADDRESS_STREET=CALLE EJEMPLO
DEFAULT_ADDRESS_ZIP=12345
# Location identifiers to skip during address resolution (comma-separated)
ADDRESS_IDENTIFIERS_SKIP=LOCATION1,LOCATION2,LOCATION3

# ====== SECURITY ======
# API key for REST endpoint authentication (x-api-key header)
SAGECONNECT_API_KEY=your_api_key_here

# ====== SCHEDULE ======
# Cron expression for background cycle (default: every 15 minutes)
# CRON_SCHEDULE=*/15 * * * *
# Delay between operations in milliseconds (default: 5000)
# OPERATION_DELAY_MS=5000

# ----- Timeouts (v2.3 Scheduler Lock Recovery) -----
# Defense-in-depth invariant: PORTAL_HTTP_TIMEOUT_MS (30s) < STEP_TIMEOUT_MS (5m) < CHILD_PROCESS_TIMEOUT_MS (10m) < LOCK_TIMEOUT_MS (14m)
# Todos opcionales — defaults sensatos en src/config.js si no se setean.
# Range guards fail-fast: si setea valor < min, process.exit(1) con [CONFIG ERROR] al startup.

# Auto-release de locks huérfanos en OperationManager (REC-01)
# Default 14 min ≈ 93% de la cadencia cron de 15 min. Min: 60000 (1 min).
# LOCK_TIMEOUT_MS=840000

# Kill cascade de ImportaFacturasFocaltec.exe (ROOT-02)
# Default 10 min. Min: 60000 (1 min). Dispara SIGTERM → 30s grace hardcoded → taskkill /F /T.
# Solo este timeout dispara email a LICENSE_ADMIN_EMAIL (D-15: evita inbox flood).
# CHILD_PROCESS_TIMEOUT_MS=600000

# Per-step Promise.race en forResponse (ROOT-03)
# Default 5 min. Min: 30000 (30 sec). Wraps 7 step blocks:
# buildProviders, downloadCFDI, checkPayments, uploadPayments,
# createPurchaseOrders, processOrderChanges, closePurchaseOrders.
# STEP_TIMEOUT_MS=300000

# ====== LICENSE ======
# License validation service connection
LICENSE_API_URL=https://your-license-server.example.com
# Shared secret for response verification
HMAC_SECRET=your_hmac_secret_here
# Admin email for service notifications
LICENSE_ADMIN_EMAIL=admin@example.com
